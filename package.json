{
  "name": "consent-kit",
  "version": "0.1.0",
  "description": "Lightweight, GDPR-minded cookie-consent toolkit for React and Next.js. Config-driven, i18n-agnostic, SSR-safe, with Do Not Track and Global Privacy Control support.",
  "keywords": [
    "cookie-consent",
    "consent",
    "gdpr",
    "ccpa",
    "privacy",
    "cookie-banner",
    "react",
    "nextjs",
    "do-not-track",
    "global-privacy-control"
  ],
  "license": "MIT",
  "author": "Ivan Naranjo (https://github.com/ivandrenc)",
  "homepage": "https://github.com/ivandrenc/consent-kit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ivandrenc/consent-kit.git"
  },
  "bugs": {
    "url": "https://github.com/ivandrenc/consent-kit/issues"
  },
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build && npm run test && npm run typecheck"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "engines": {
    "node": ">=20"
  }
}
